def make_precip_map(data, lons, lats, cmap_name, vmin, vmax, title=""):
    fig = go.Figure(go.Heatmap(
        z          = data,
        x          = lons,
        y          = lats,
        zmin       = vmin,
        zmax       = vmax,
        colorscale = cmap_name,
        colorbar   = dict(
            title       = dict(text="mm/yr", side="right",
                               font=dict(size=11, color="#8b949e")),
            tickfont    = dict(size=10, color="#8b949e"),
            thickness   = 14,
            len         = 0.75,
            bgcolor     = "rgba(22,27,34,0.8)",
            bordercolor = "#30363d",
            borderwidth = 1,
        ),
        hovertemplate="Lon: %{x:.2f}°<br>Lat: %{y:.2f}°<br>Precip Trend: %{z:.4f} mm/yr<extra></extra>",
    ))
    # Overlay country centroids coloured by HDI tier
    for tier, color in HDI_TIER_COLORS.items():
        subset = HDI_DF[HDI_DF["tier"] == tier]
        if len(subset) == 0:
            continue
        fig.add_trace(go.Scatter(
            x    = subset["lon"],
            y    = subset["lat"],
            mode = "markers",
            name = tier,
            marker = dict(
                color  = color,
                size   = 7,
                line   = dict(color="#0f1117", width=0.8),
