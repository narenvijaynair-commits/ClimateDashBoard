            gridcolor = "#21262d",
            zeroline  = True,
            zerolinecolor = "#30363d",
            zerolinewidth = 1,
        ),
        legend = dict(
            bgcolor    = "rgba(22,27,34,0.9)",
            bordercolor= "#30363d",
            borderwidth= 1,
            font       = dict(color="#8b949e", size=10),
            title      = dict(text=legend_title, font=dict(color="#8b949e", size=10)),
