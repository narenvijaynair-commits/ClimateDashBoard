    colors = ["#3498db" if v > 0 else "#e74c3c" for v in zonal[valid]]
    fig = go.Figure(go.Bar(
        x                 = zonal[valid],
        y                 = lats[valid],
        orientation       = "h",
        marker_color      = colors,
        marker_line_width = 0,
        hovertemplate     = "Lat: %{y:.1f}°<br>Mean Trend: %{x:.4f} mm/yr<extra></extra>",
    ))
    fig.add_vline(x=0, line_color="#8b949e", line_dash="dash", line_width=1)
    fig.update_layout(
        xaxis        = dict(title="Mean Precip Trend (mm/yr)", color="#8b949e",
