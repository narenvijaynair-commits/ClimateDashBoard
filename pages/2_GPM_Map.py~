def make_scatter(df, color_mode="region", show_regression=True,
                 x_col="hdi", y_col="precip_trend"):
    if color_mode == "region":
        color_col   = "region"
        color_map   = REGION_COLORS
        legend_title= "Region"
    else:
        color_col   = "tier"
        color_map   = HDI_TIER_COLORS
        legend_title= "HDI Tier"

    traces = []
    for group_val in df[color_col].unique():
        sub = df[df[color_col] == group_val]
        color = color_map.get(group_val, "#8b949e")
        traces.append(go.Scatter(
            x              = sub[x_col],
            y              = sub[y_col],
            mode           = "markers",
            name           = group_val,
            marker         = dict(color=color, size=9,
                                  line=dict(color="#0f1117", width=0.8)),
            text           = sub["country"],
            hovertemplate  = (
                "<b>%{text}</b><br>"
                f"HDI: %{{x:.3f}}<br>"
                f"Precip Trend: %{{y:.4f}} mm/yr<extra></extra>"
            ),
        ))

    fig = go.Figure(traces)

    if show_regression and HAS_SCIPY and len(df) > 3:
        valid = df[[x_col, y_col]].dropna()
        slope, intercept, r_value, p_value, _ = stats.linregress(
            valid[x_col], valid[y_col]
        )
        x_range = np.linspace(valid[x_col].min(), valid[x_col].max(), 100)
        y_range = slope * x_range + intercept
        fig.add_trace(go.Scatter(
            x          = x_range,
            y          = y_range,
            mode       = "lines",
            name       = f"OLS fit (r²={r_value**2:.3f}, p={p_value:.3f})",
            line       = dict(color="#58a6ff", width=2, dash="dash"),
            showlegend = True,
        ))
        # Annotation
        fig.add_annotation(
            x    = valid[x_col].max() * 0.97,
            y    = y_range[-1],
            text = (f"r² = {r_value**2:.3f}<br>"
                    f"p  = {p_value:.4f}<br>"
                    f"slope = {slope:.4f}"),
            showarrow   = False,
            font        = dict(color="#58a6ff", size=11, family="IBM Plex Mono"),
            bgcolor     = "rgba(22,27,34,0.85)",
            bordercolor = "#30363d",
            borderwidth = 1,
            align       = "right",
        )

    fig.update_layout(
        xaxis = dict(
            title     = "Human Development Index (HDI, 2022)",
            color     = "#8b949e",
            tickfont  = dict(size=10),
            gridcolor = "#21262d",
            range     = [0.35, 1.00],
