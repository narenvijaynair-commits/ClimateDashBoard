# Data loading
# ═══════════════════════════════════════════════════════════════════════════════
@st.cache_data(show_spinner="Loading GeoTIFF…")
def load_tiff(path: str, downsample: int = 4):
    if not HAS_RASTERIO:
        return None
    with rasterio.open(path) as src:
        data = src.read(
            1,
            out_shape=(
                max(1, src.height // downsample),
                max(1, src.width  // downsample),
            ),
            resampling=rasterio.enums.Resampling.average,
        ).astype(float)
        bounds     = src.bounds
        nodata     = src.nodata
        crs        = str(src.crs)
        orig_shape = (src.height, src.width)
        res        = src.res

    if nodata is not None:
        data = np.where(data == nodata, np.nan, data)
    data = np.where(np.abs(data) > 1e10, np.nan, data)

    lons = np.linspace(bounds.left,  bounds.right,  data.shape[1])
    lats = np.linspace(bounds.top,   bounds.bottom, data.shape[0])

    return {
        "data"       : data,
        "lons"       : lons,
        "lats"       : lats,
        "bounds"     : bounds,
        "crs"        : crs,
        "orig_shape" : orig_shape,
        "res"        : res,
        "nodata"     : nodata,
    }


def crop_to_region(raster, region_bounds):
    lon_min, lat_min, lon_max, lat_max = region_bounds
    lons, lats, data = raster["lons"], raster["lats"], raster["data"]
    col_mask = (lons >= lon_min) & (lons <= lon_max)
    row_mask = (lats >= lat_min) & (lats <= lat_max)
    return data[np.ix_(row_mask, col_mask)], lons[col_mask], lats[row_mask]


def sample_raster_at_point(raster, lat, lon, radius_deg=2.0):
    """Return mean raster value within radius_deg of (lat, lon)."""
    lons, lats, data = raster["lons"], raster["lats"], raster["data"]
    col_mask = (lons >= lon - radius_deg) & (lons <= lon + radius_deg)
    row_mask = (lats >= lat - radius_deg) & (lats <= lat + radius_deg)
    patch = data[np.ix_(row_mask, col_mask)]
    valid = patch[~np.isnan(patch)]
    return float(np.mean(valid)) if len(valid) > 0 else np.nan


@st.cache_data(show_spinner="Sampling precipitation at country centroids…")
def build_hdi_precip_df(_raster_data, _raster_lons, _raster_lats, radius_deg=2.5):
    """
    For each country in HDI_DF, sample the mean precipitation trend within
    radius_deg of its centroid. Returns merged DataFrame.
    """
    raster_proxy = {
        "lons": _raster_lons,
        "lats": _raster_lats,
        "data": _raster_data,
    }
    precip_vals = []
    for _, row in HDI_DF.iterrows():
        val = sample_raster_at_point(raster_proxy, row["lat"], row["lon"], radius_deg)
        precip_vals.append(val)

    df = HDI_DF.copy()
    df["precip_trend"] = precip_vals
    df = df.dropna(subset=["precip_trend"])
    return df


