def render_card(col, key, val, gmean, meta):
    """Render one index card in the given column."""
    label    = meta['label']
    units    = meta['units']
    icon     = meta['icon']
    source   = meta['source']
    pos_good = meta['pos_good']

    with col:
        if val is None:
            st.markdown(
                f"""
                <div class="index-card">
                    <div class="ic-label">{icon} {label}</div>
                    <div class="ic-value" style="color:#4a7a8a;">—</div>
                    <div class="ic-units">Data not available</div>
                    <div class="ic-source">{source}</div>
                </div>
                """,
                unsafe_allow_html=True,
            )
            return

        val_color = "#00e5cc" if val > 0 else "#f85149"

        if gmean is not None:
            delta    = val - gmean
            pct      = (delta / abs(gmean) * 100) if gmean != 0 else 0
            arrow    = "▲" if delta >= 0 else "▼"
            # Assess if above-global is "good" or "bad" for this index
            is_good  = (delta >= 0) == pos_good
            d_color  = "#2ecc71" if is_good else "#e74c3c"
            delta_str = f"{arrow} {abs(pct):.1f}% vs global mean ({gmean:+.4f} {units})"
        else:
            delta_str = ""
            d_color   = "#8b949e"

        st.markdown(
            f"""
            <div class="index-card">
                <div class="ic-label">{icon} {label}</div>
                <div class="ic-value" style="color:{val_color};">{val:+.4f}</div>
                <div class="ic-delta" style="color:{d_color};">{delta_str}</div>
                <div class="ic-units">{units}</div>
                <div class="ic-source">{source}</div>
            </div>
            """,
            unsafe_allow_html=True,
        )


