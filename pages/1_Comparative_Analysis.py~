@st.cache_data
def load_hdi():
    df = pd.read_csv('HDR25_Statistical_Annex_HDI_Table.csv', skiprows=3)
    df.columns = df.columns.str.strip()
    country_col = 'Country' if 'Country' in df.columns else df.columns[1]
    value_col   = df.columns[2]
    df[country_col] = df[country_col].str.strip()
    df[value_col]   = pd.to_numeric(df[value_col], errors='coerce')
    df = df.dropna(subset=[country_col, value_col])
    return dict(zip(df[country_col].str.lower(), df[value_col]))


@st.cache_data
def load_csv_index(filepath, country_col, trend_col):
    """Load a CSV-based index, return {country_lower: (value, global_mean)}."""
    import os
    if not os.path.exists(filepath):
        return None, None
    df = pd.read_csv(filepath)
    df[country_col] = df[country_col].str.strip().str.lower()
    df = df.drop_duplicates(subset=country_col)
    df[trend_col] = pd.to_numeric(df[trend_col], errors='coerce')
    df = df.dropna(subset=[trend_col])
    lookup = dict(zip(df[country_col], df[trend_col]))
    global_mean = float(df[trend_col].mean())
    return lookup, global_mean


@st.cache_data
def load_giss_index():
    """Load GISTEMP NetCDF, return {country_lower: value} and global mean."""
    import os
    if not os.path.exists('GISS_temperature_trend_1980_2025.nc'):
        return None, None
    try:
        import netCDF4 as nc
    except ImportError:
        return None, None
    ds   = nc.Dataset('GISS_temperature_trend_1980_2025.nc', 'r')
    lat  = ds.variables['lat'][:]
    lon  = ds.variables['lon'][:]
    data = ds.variables['TEMPTREND'][:]
    miss = ds.variables['TEMPTREND'].missing_value
    ds.close()

    def sample(lat_c, lon_c, window=3):
        li = np.abs(lat - lat_c).argmin()
        lj = np.abs(lon - lon_c).argmin()
        chunk = data[max(0,li-window):li+window+1,
                     max(0,lj-window):lj+window+1]
        valid = chunk[chunk != miss]
        return float(np.mean(valid)) if len(valid) > 0 else np.nan

    lookup = {}
    vals   = []
    for c_lower, coords in COUNTRY_COORDS.items():
        v = sample(*coords)
        if not np.isnan(v):
            lookup[c_lower] = v
            vals.append(v)
    global_mean = float(np.mean(vals)) if vals else np.nan
    return lookup, global_mean


@st.cache_data
def load_tif_index(filepath):
    """Sample a GeoTIFF at every country centroid. Return lookup + global mean."""
    import os
    if not os.path.exists(filepath) or not HAS_RASTERIO:
        return None, None
    try:
        with rasterio.open(filepath) as src:
            nodata = src.nodata
            lookup = {}
            vals   = []
            for c_lower, (lat_c, lon_c) in COUNTRY_COORDS.items():
                try:
                    row, col = src.index(lon_c, lat_c)
                    h, w = src.height, src.width
                    r0 = max(0, row-2); r1 = min(h, row+3)
                    c0 = max(0, col-2); c1 = min(w, col+3)
                    patch = src.read(1, window=rasterio.windows.Window(
                        c0, r0, c1-c0, r1-r0)).astype(float)
                    if nodata is not None:
                        patch = np.where(patch == nodata, np.nan, patch)
                    patch = np.where(np.abs(patch) > 1e10, np.nan, patch)
                    valid = patch[~np.isnan(patch)]
                    if len(valid) > 0:
                        v = float(np.mean(valid))
                        lookup[c_lower] = v
                        vals.append(v)
                except Exception:
                    continue
        global_mean = float(np.mean(vals)) if vals else np.nan
        return lookup, global_mean
    except Exception:
        return None, None


def resolve_country(raw_name):
    """Resolve a display name to its canonical lower-case HDI key."""
    lower = raw_name.strip().lower()
    return ALIASES.get(lower, lower)


def get_all_indices(canonical_lower):
    """Return a dict of key → (value, global_mean) for all indices."""
    results = {}

    # CSV-based indices
    for key, meta in INDICES.items():
        if meta['kind'] != 'csv':
            continue
        lookup, gmean = load_csv_index(meta['file'], meta['country_col'], meta['trend_col'])
        if lookup is None:
            results[key] = (None, None)
            continue
        # Try direct match, then alias
        val = lookup.get(canonical_lower)
        if val is None:
            val = lookup.get(ALIASES.get(canonical_lower, ''))
        results[key] = (val, gmean)

    # GISTEMP
    lookup_giss, gmean_giss = load_giss_index()
    if lookup_giss is not None:
        val = lookup_giss.get(canonical_lower)
        results['giss_temp'] = (val, gmean_giss)
    else:
        results['giss_temp'] = (None, None)

    # GeoTIFF indices
    for key, meta in INDICES.items():
        if meta['kind'] != 'tif':
            continue
        lookup_tif, gmean_tif = load_tif_index(meta['file'])
        if lookup_tif is None:
            results[key] = (None, None)
            continue
        val = lookup_tif.get(canonical_lower)
        results[key] = (val, gmean_tif)

    return results


